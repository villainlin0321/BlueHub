<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application>
        <!-- Keep a direct launcher activity in debug so `flutter run` can
             resolve and start the app, while release uses alias entries only. -->
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Disable alias launchers in debug so the installed debug build keeps
             a single launcher icon while release still supports dynamic icons. -->
        <activity-alias
            android:name=".MainActivityDefault"
            android:enabled="false"
            tools:replace="android:enabled" />
        <activity-alias
            android:name=".MainActivityZh"
            android:enabled="false"
            tools:replace="android:enabled" />
    </application>
</manifest>
